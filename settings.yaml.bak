theme: dark
colors:
  text: default
  folder: cyan
  file: blue
  success: green
  warning: yellow
  error: red bold
  info: blue
table:
  border: dim
  header_style: bold
transfer:
  default_jobs: 4
  chunk_size: 65536
  timeout: 60
search:
  default_depth: 3
  max_depth: 10
network:
  max_retries: 10
  retry_backoff: 1
  request_timeout: 60
